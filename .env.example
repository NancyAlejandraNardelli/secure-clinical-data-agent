# Configuración para Kaggle / GitHub Evaluators (Modo Fallback CSV)
# ----------------------------------------------------------------
# Si no posees SQL Server, simplemente deja DB_HOST inválido y el sistema
# usará de forma automática DuckDB sobre el archivo CSV proporcionado.

USE_GEMINI=true
GEMINI_API_KEY=Pega_aqui_tu_api_key_de_gemini

# Forzar Fallback a CSV desactivando el host de la DB (o déjalo vacío)
DB_HOST=invalido

# Configuración del Hospital (Solo si se cuenta con la DB conectada)
# ----------------------------------------------------------------
# DB_HOST=MI_SERVIDOR_SQL
# DB_NAME=HCJS
# DB_USER=usuario
# DB_PASSWORD=contraseña
# DB_PORT=1433
# OLLAMA_API_BASE=http://localhost:11434
# LLM_MODEL_QA=ministral-3:3b-instruct-2512-q8_0
